---
import { Icon } from "astro-icon";
import type { SocialLink } from "~/types";

const links: SocialLink[] = [
  {
    url: 'https://github.com/jef586',
    label: 'GitHub',
    icon: 'fa-brands:github-alt',
  },
  {
    url: 'https://www.linkedin.com/in/ezequiel-flores-4343391a8/',
    label: 'LinkedIn',
    icon: 'fa-brands:linkedin',
  },
  {
    url: 'https://wa.me/+5492645172697',
    label: 'WhatsApp',
    icon: 'mdi:whatsapp',
  },
  {
    url: 'mailto:ezequiel.flores@email.com',
    label: 'Email',
    icon: 'mdi:email',
  },
];
---

<section
  id="contact"
  class="relative py-32 px-6"
>
  <div class="container mx-auto max-w-4xl text-center">
    <div class="glass rounded-3xl p-10 md:p-16 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/5 via-transparent to-purple-600/5" />
      <div class="absolute -top-24 -right-24 w-48 h-48 bg-cyan-500/10 rounded-full blur-3xl" />
      <div class="absolute -bottom-24 -left-24 w-48 h-48 bg-purple-600/10 rounded-full blur-3xl" />

      <div class="relative z-10">
        <span class="inline-block px-3 py-1 text-xs font-medium rounded-full border border-cyan-500/20 bg-cyan-500/5 text-cyan-400 mb-4">
          Contacto
        </span>
        <h2 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4">
          <span class="gradient-cyan-purple">Trabajemos Juntos</span>
        </h2>
        <p class="text-offset text-lg max-w-2xl mx-auto mb-8">
          Estoy abierto a nuevas oportunidades como QA Automation Engineer, SDET o Frontend Developer. Si buscas profesionalismo, pruebas confiables y código limpio, hablemos.
        </p>

        <div class="flex flex-wrap justify-center gap-3 mb-10">
          <a
            href="/cv.pdf"
            download
            class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-gradient-to-r from-cyan-500 to-blue-600 text-white font-semibold text-sm hover:shadow-lg hover:shadow-cyan-500/25 transition-all duration-300 hover:-translate-y-0.5"
          >
            <Icon pack="mdi" name="download" class="h-5 w-5" />
            Descargar CV
          </a>
          <a
            href="https://wa.me/+5492645172697"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-emerald-500/10 border border-emerald-500/30 text-emerald-400 font-semibold text-sm hover:bg-emerald-500/20 transition-all duration-300"
          >
            <Icon pack="mdi" name="whatsapp" class="h-5 w-5" />
            WhatsApp
          </a>
          <a
            href="https://www.linkedin.com/in/ezequiel-flores-4343391a8/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-blue-500/10 border border-blue-500/30 text-blue-400 font-semibold text-sm hover:bg-blue-500/20 transition-all duration-300"
          >
            <Icon name="fa-brands:linkedin" class="h-5 w-5" />
            LinkedIn
          </a>
        </div>

        <div class="flex items-center justify-center gap-6">
          {
            links.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-offset hover:text-default transition-colors duration-200"
                aria-label={link.label}
              >
                <Icon name={link.icon} class="h-6 w-6" />
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
