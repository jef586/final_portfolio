---
import { Icon } from "astro-icon";
---

<footer class="relative py-12 px-6 border-t border-default">
  <div class="container mx-auto max-w-6xl">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-3">
        <Icon name="logomark" class="h-6 text-cyan-400" />
        <span class="text-sm text-offset">
          &copy; {new Date().getFullYear()} Ezequiel Flores
        </span>
      </div>
      <div class="flex items-center gap-4">
        <a
          href="https://github.com/jef586"
          target="_blank"
          rel="noopener noreferrer"
          class="text-offset hover:text-default transition-colors"
          aria-label="GitHub"
        >
          <Icon name="fa-brands:github-alt" class="h-5 w-5" />
        </a>
        <a
          href="https://www.linkedin.com/in/ezequiel-flores-4343391a8/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-offset hover:text-default transition-colors"
          aria-label="LinkedIn"
        >
          <Icon name="fa-brands:linkedin" class="h-5 w-5" />
        </a>
        <a
          href="https://wa.me/+5492645172697"
          target="_blank"
          rel="noopener noreferrer"
          class="text-offset hover:text-default transition-colors"
          aria-label="WhatsApp"
        >
          <Icon pack="mdi" name="whatsapp" class="h-5 w-5" />
        </a>
        <a
          href="https://gitlab.com/jeftikas"
          target="_blank"
          rel="noopener noreferrer"
          class="text-offset hover:text-default transition-colors"
          aria-label="GitLab"
        >
          <Icon name="fa-brands:gitlab" class="h-5 w-5" />
        </a>
      </div>
      <div class="flex items-center gap-2">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-xs">
          <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse" />
          Open to work
        </span>
      </div>
    </div>
  </div>
</footer>
