---
import { Icon } from "astro-icon";
---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[#08080f]"
>
  <div class="absolute inset-0 bg-gradient-to-br from-cyan-900/20 via-transparent to-purple-900/20" />

  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-cyan-500/10 rounded-full blur-3xl animate-pulse-glow" />
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-purple-600/10 rounded-full blur-3xl animate-pulse-glow" style="animation-delay: 2s" />
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-blue-500/5 rounded-full blur-3xl" />
  </div>

  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.015)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.015)_1px,transparent_1px)] bg-[size:64px_64px]" />

  <div class="relative z-10 container mx-auto px-6 text-center">
    <div class="flex flex-wrap justify-center gap-2 mb-8 animate-fade-in-up">
      {
        ['Playwright', 'Cypress', 'Vue', 'Laravel', 'APIs', 'CI/CD', 'GitHub Actions'].map(
          (badge) => (
            <span
              class="px-3 py-1.5 text-xs font-medium rounded-full border border-cyan-500/20 bg-cyan-500/5 text-cyan-400"
            >
              {badge}
            </span>
          ),
        )
      }
    </div>

    <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-extrabold tracking-tight leading-tight mb-6 animate-fade-in-up-delay-1">
      <span class="gradient-cyan-purple">
        QA Automation Engineer
      </span>
      <br />
      <span class="text-white">+ Frontend Developer</span>
    </h1>

    <p class="text-lg sm:text-xl md:text-2xl text-gray-400 max-w-3xl mx-auto mb-10 leading-relaxed animate-fade-in-up-delay-2">
      Creo pruebas E2E confiables con Playwright/Cypress y desarrollo interfaces modernas con Vue para productos reales.
    </p>

    <div class="flex flex-wrap justify-center gap-4 animate-fade-in-up-delay-3">
      <a
        href="#projects"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-full bg-gradient-to-r from-cyan-500 to-blue-600 text-white font-semibold text-sm hover:shadow-lg hover:shadow-cyan-500/25 transition-all duration-300 hover:-translate-y-0.5"
      >
        <Icon pack="mdi" name="briefcase" class="h-5 w-5" />
        Ver proyectos
      </a>
      <a
        href="/cv.pdf"
        download
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-full border border-cyan-500/30 text-cyan-400 font-semibold text-sm hover:bg-cyan-500/10 hover:border-cyan-500/50 transition-all duration-300"
      >
        <Icon pack="mdi" name="download" class="h-5 w-5" />
        Descargar CV
      </a>
      <a
        href="https://www.linkedin.com/in/ezequiel-flores-4343391a8/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-full border border-purple-500/30 text-purple-400 font-semibold text-sm hover:bg-purple-500/10 hover:border-purple-500/50 transition-all duration-300"
      >
        <Icon name="fa-brands:linkedin" class="h-5 w-5" />
        Contactar por LinkedIn
      </a>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <Icon pack="mdi" name="chevron-double-down" class="h-8 w-8 text-gray-600" />
  </div>
</section>
